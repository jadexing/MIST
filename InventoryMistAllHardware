"""
APIs Called

Get Sites

GET /api/v1/orgs/{org_id}/sites


Retrieves all sites in the organization
Used to build a lookup of site ID → site name


Get Organization Inventory (Paginated)

GET /api/v1/orgs/{org_id}/inventory
  ?limit=100
  &page=n


Retrieves all devices across the organization (APs, switches, gateways, etc.)
Uses pagination to collect the full inventory

Summary
This script performs a read‑only, organization‑wide inventory export from the Mist AC2 cloud. It retrieves all sites, then pulls the full device inventory at the org level, maps devices to their respective sites, and aggregates device counts by model per site. The results are written to a timestamped CSV that includes per‑site totals and overall organization totals, making the output suitable for inventory tracking, audits, and hardware lifecycle planning.

"""

import requests
import csv
import os
from collections import defaultdict
from datetime import datetime
import time

BASE_URL = "https://api.ac2.mist.com/api/v1"


def read_file(filename):

    if os.path.exists(filename):
        with open(filename, "r") as f:
            return f.read().strip()

    return None


print("\nMist Full Inventory Export\n")

token = read_file("MyKey.txt")
org_id = read_file("Org.txt")

if not token:
    token = input("Enter Mist API Token: ").strip()

if not org_id:
    org_id = input("Enter Org ID: ").strip()

headers = {
    "Authorization": f"Token {token}",
    "Content-Type": "application/json"
}

start_time = time.time()

# -------------------------
# GET SITES
# -------------------------

print("Retrieving sites...")

sites_url = f"{BASE_URL}/orgs/{org_id}/sites"

response = requests.get(sites_url, headers=headers)

if response.status_code != 200:
    print("Error retrieving sites:")
    print(response.text)
    exit()

sites = response.json()

if not isinstance(sites, list):
    print("Unexpected response retrieving sites:")
    print(sites)
    exit()

site_lookup = {}

for site in sites:
    site_lookup[site["id"]] = site["name"]

print(f"Found {len(site_lookup)} sites")

# -------------------------
# GET INVENTORY (Paginated)
# -------------------------

print("\nRetrieving organization inventory...")

inventory = []
page = 1

while True:

    url = f"{BASE_URL}/orgs/{org_id}/inventory?limit=100&page={page}"

    response = requests.get(url, headers=headers)

    if response.status_code != 200:
        print("Error retrieving inventory:")
        print(response.text)
        exit()

    data = response.json()

    if not data:
        break

    inventory.extend(data)

    print(f"Retrieved page {page} ({len(data)} devices)")

    page += 1

print(f"\nTotal devices retrieved: {len(inventory)}")

# -------------------------
# PROCESS DATA
# -------------------------

site_model_counts = defaultdict(lambda: defaultdict(int))
models = set()

print("\nProcessing devices...")

for device in inventory:

    model = device.get("model", "Unknown")
    site_id = device.get("site_id")

    if site_id in site_lookup:
        site_name = site_lookup[site_id]
    else:
        site_name = "Unassigned"

    site_model_counts[site_name][model] += 1
    models.add(model)

models = sorted(models)

print(f"Unique models found: {len(models)}")

# -------------------------
# CREATE CSV
# -------------------------

timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
filename = f"MistInventory_{timestamp}.csv"

print(f"\nWriting CSV: {filename}")

column_totals = defaultdict(int)

with open(filename, "w", newline="") as f:

    writer = csv.writer(f)

    header = ["Site"] + models + ["Total"]
    writer.writerow(header)

    for site in sorted(site_model_counts):

        row = [site]
        row_total = 0

        for model in models:

            count = site_model_counts[site].get(model, 0)

            row.append(count)
            row_total += count
            column_totals[model] += count

        row.append(row_total)

        writer.writerow(row)

    total_row = ["TOTAL"]
    grand_total = 0

    for model in models:

        total = column_totals[model]
        total_row.append(total)
        grand_total += total

    total_row.append(grand_total)

    writer.writerow(total_row)

# -------------------------
# FINISH
# -------------------------

runtime = round(time.time() - start_time, 2)

print("\nExport Complete")
print(f"Runtime: {runtime} seconds")
print(f"CSV created: {filename}\n")
