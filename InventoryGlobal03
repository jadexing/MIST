import requests
import csv
import time
from datetime import datetime
from collections import defaultdict


# Mist Global 03 (ac2) API endpoint
BASE_URL = "https://api.ac2.mist.com/api/v1"


# --- Prompt for API key (paste-friendly) ---
def get_api_key():

    print("\nPaste your Mist API key and press Enter:")
    api_key = input().strip()

    if not api_key:
        print("Error: API key cannot be empty.")
        exit()

    return api_key


# --- Load Org ID safely ---
def get_org_id(filename):

    try:
        with open(filename, 'r') as file:
            org_id = file.read().strip()

            if not org_id:
                raise ValueError("Org ID file is empty.")

            return org_id

    except FileNotFoundError:
        print(f"Error: The file '{filename}' was not found.")
        exit()

    except ValueError as ve:
        print(f"Error: {ve}")
        exit()


# --- Test API connectivity ---
def test_api(headers):

    url = f"{BASE_URL}/self"

    response = requests.get(url, headers=headers)

    response.raise_for_status()

    return response.json()


# --- Generic paginated GET function ---
def paginated_get(url, headers):

    results = []

    limit = 100
    page = 1

    while True:

        params = {
            "limit": limit,
            "page": page
        }

        response = requests.get(
            url,
            headers=headers,
            params=params
        )

        response.raise_for_status()

        data = response.json()

        if not data:
            break

        results.extend(data)

        if len(data) < limit:
            break

        page += 1

    return results


# --- Get all sites for org ---
def get_sites(org_id, headers):

    url = f"{BASE_URL}/orgs/{org_id}/sites"

    return paginated_get(url, headers)


# --- Get all devices for site ---
def get_devices(site_id, headers):

    url = f"{BASE_URL}/sites/{site_id}/devices"

    return paginated_get(url, headers)


# --- Count AP models ---
def count_models(devices):

    models = defaultdict(int)

    for device in devices:

        model = device.get("model", "Unknown")

        models[model] += 1

    return models


# --- Main function ---
def main():

    start_time = time.time()

    # --- Credentials ---
    api_key = get_api_key()
    org_id = get_org_id("Org.txt")

    headers = {
        "Authorization": f"Token {api_key}",
        "Content-Type": "application/json"
    }

    # --- Test API ---
    print("\nTesting Mist API connection...")

    try:
        self_info = test_api(headers)
        print("API authentication successful.")
        print(f"Logged in as: {self_info.get('email', 'Unknown')}")

    except requests.exceptions.HTTPError as e:
        print(f"API authentication failed: {e}")
        return

    except requests.exceptions.RequestException as e:
        print(f"API connection error: {e}")
        return

    # --- Get sites ---
    print("\nRetrieving sites...")

    try:
        sites = get_sites(org_id, headers)

    except requests.exceptions.RequestException as e:
        print(f"Unable to retrieve sites: {e}")
        return

    if not sites:
        print("No sites found.")
        return

    results = []
    org_model_totals = defaultdict(int)

    total_sites = len(sites)

    # --- Process sites ---
    for index, site in enumerate(sites, start=1):

        site_name = site.get("name", "Unknown Site")
        site_id = site.get("id")

        print(f"[{index}/{total_sites}] Checking site: {site_name}")

        try:
            devices = get_devices(site_id, headers)

        except requests.exceptions.RequestException as e:
            print(f"  Skipping {site_name}: {e}")
            continue

        model_counts = count_models(devices)
        site_total = sum(model_counts.values())

        for model, count in sorted(model_counts.items()):

            results.append({
                "Site": site_name,
                "Model": model,
                "Count": count,
                "Site Total APs": site_total
            })

            org_model_totals[model] += count

    # --- Export CSV ---
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = f"MistAPInventory_{timestamp}.csv"

    with open(filename, "w", newline="") as csvfile:

        fieldnames = ["Site", "Model", "Count", "Site Total APs"]

        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)
        writer.writeheader()

        for row in results:
            writer.writerow(row)

    # --- Totals ---
    print("\n--- Organization Model Totals ---")

    for model, total in sorted(org_model_totals.items()):
        print(f"{model}: {total}")

    runtime = round(time.time() - start_time, 2)

    print(f"\nCSV Exported: {filename}")
    print(f"Total Runtime: {runtime} seconds")


# --- Run ---
if __name__ == "__main__":
    main()
