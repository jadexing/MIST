"""
Here’s a **condensed, executive‑ready version** that does exactly what you asked: states the **three required definition files**, lists the **API(s) called**, then provides a short summary.

***

## Required Definition Files

This script requires **three configuration files**, all located in the same directory as the script:

1.  **Base.txt**
    *   Contains the Mist API base URL
    *   Example: `https://api.mist.com/api/v1`

2.  **MyKey.txt**
    *   Contains the Mist **API token** (org‑scoped)

3.  **Org.txt**
    *   Contains the **Mist Organization ID**

***

## APIs Called

*   **GET `/api/v1/orgs/{org_id}/sites`**
    *   Retrieves all sites for the specified organization
    *   Uses pagination (`limit=100`, `page=n`) to return the full site list

***

## Summary

This script performs a **read‑only query** against the Mist API to retrieve and display all sites within a specified organization. It forces IPv4 to avoid DNS or VPN‑related issues, reads required configuration values from local files, authenticates using a Mist API token, and iterates through paginated results. The output is a simple list of site names and IDs, making the script suitable for validation, inventory, or as a foundation for additional Mist automation.
"""


import socket
import requests
import os

# ====== DNS workaround (forces IPv4) ======
old_getaddrinfo = socket.getaddrinfo
def getaddrinfo_ipv4(host, port, *args, **kwargs):
    return [info for info in old_getaddrinfo(host, port, *args, **kwargs) if info[0] == socket.AF_INET]
socket.getaddrinfo = getaddrinfo_ipv4

# ====== CONFIG FILES ======
BASE_FILE = "Base.txt"   # Should contain e.g., https://api-ac2.mist.com/api/v1
KEY_FILE = "MyKey.txt"   # Your superuser API token
ORG_FILE = "Org.txt"     # Your Org ID
# ==========================================

def read_file(filename):
    if not os.path.exists(filename):
        raise Exception(f"{filename} not found in the script folder.")
    with open(filename, "r") as f:
        return f.read().strip()

def get_sites(base_url, org_id, headers):
    print(f"Retrieving sites for org {org_id} at {base_url} ...")
    sites = []
    page = 1
    while True:
        url = f"{base_url}/orgs/{org_id}/sites?limit=100&page={page}"
        try:
            r = requests.get(url, headers=headers, timeout=10)
            r.raise_for_status()
        except requests.exceptions.HTTPError as e:
            print("HTTP error:", e)
            return []
        except requests.exceptions.RequestException as e:
            print("Request error:", e)
            return []
        
        data = r.json()
        if not data:
            break
        sites.extend(data)
        page += 1
    return sites

def main():
    try:
        BASE_URL = read_file(BASE_FILE)
        API_KEY = read_file(KEY_FILE)
        ORG_ID = read_file(ORG_FILE)
    except Exception as e:
        print("Error reading config files:", e)
        return

    HEADERS = {
        "Authorization": f"Token {API_KEY}",
        "Content-Type": "application/json"
    }

    sites = get_sites(BASE_URL, ORG_ID, HEADERS)
    if not sites:
        print("No sites found or there was an error retrieving sites.")
        return

    print(f"\nFound {len(sites)} site(s):\n")
    for site in sites:
        print(f"- {site.get('name', 'Unknown')} (ID: {site.get('id', 'Unknown')})")

if __name__ == "__main__":
    main()
